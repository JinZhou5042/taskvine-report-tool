# Include documentation and configuration files
include README.md
include requirements.txt
include MANIFEST.in

# Include static web assets
recursive-include src/vine_serve/static *
recursive-include src/vine_serve/templates *

# Include Python files
recursive-include src/vine_serve *.py

# Exclude development and build artifacts
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude __pycache__
global-exclude .DS_Store
global-exclude *.so
global-exclude .git*
prune logs
prune test
prune imgs
prune pyplot
prune .ruff_cache
prune __pycache__ 